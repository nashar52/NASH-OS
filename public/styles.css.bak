:root {
  --bg: #07152a;
  --panel: rgba(10, 38, 76, 0.84);
  --panel-2: rgba(4, 26, 54, 0.92);
  --line: rgba(79, 229, 255, 0.28);
  --text: #f4fbff;
  --muted: #a8bfd4;
  --cyan: #35f3ff;
  --cyan-2: #0ddfc9;
  --warning: #ffbd59;
  --good: #5dffb0;
  --danger: #ff6c87;
  --shadow: 0 24px 90px rgba(0,0,0,.35);
}
* { box-sizing: border-box; }
body {
  margin: 0;
  font-family: Inter, Segoe UI, Arial, sans-serif;
  background: radial-gradient(circle at top left, #093b67, #07152a 42%, #031022);
  color: var(--text);
}
.app-shell { display: grid; grid-template-columns: 292px 1fr; min-height: 100vh; }
.sidebar {
  padding: 22px;
  border-right: 1px solid var(--line);
  background: linear-gradient(180deg, rgba(3,17,37,.92), rgba(5,22,46,.78));
  position: sticky;
  top: 0;
  height: 100vh;
}
.brand-card, .lock-card, .panel, .hero {
  border: 1px solid var(--line);
  border-radius: 24px;
  background: var(--panel);
  box-shadow: var(--shadow);
}
.brand-card { display: flex; gap: 14px; align-items: center; padding: 16px; }
.brand-mark {
  width: 58px; height: 58px; border-radius: 16px;
  display: grid; place-items: center;
  background: linear-gradient(135deg, #0a67ff, #21f4ff);
  color: white; font-weight: 900; font-size: 34px;
  box-shadow: inset 0 0 22px rgba(255,255,255,.28);
}
.brand-title { font-weight: 900; letter-spacing: .1em; }
.brand-subtitle { color: var(--muted); font-size: 12px; margin-top: 4px; }
.side-section { margin-top: 24px; }
.side-label, .eyebrow { color: var(--cyan); text-transform: uppercase; letter-spacing: .16em; font-weight: 800; font-size: 12px; }
.clean-select {
  width: 100%; margin-top: 10px; padding: 14px 14px;
  background: #061a38; color: var(--text); border: 1px solid var(--line); border-radius: 14px;
}
.side-nav { margin-top: 22px; display: grid; gap: 10px; }
.nav-item {
  border: 1px solid var(--line); border-radius: 16px; padding: 13px 14px;
  background: rgba(10, 39, 78, .72); color: var(--text); text-align: left;
}
.nav-item.active { background: linear-gradient(135deg, rgba(13,223,201,.35), rgba(53,243,255,.14)); border-color: var(--cyan); }
.lock-card { margin-top: 22px; padding: 16px; display: grid; gap: 6px; }
.lock-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--good); box-shadow: 0 0 18px var(--good); }
.lock-card small { color: var(--muted); }
.main { padding: 28px; overflow: auto; }
.hero { padding: 28px; display: flex; justify-content: space-between; gap: 24px; align-items: flex-start; }
h1 { font-size: clamp(34px, 4vw, 58px); line-height: .95; margin: 8px 0; }
h2 { margin: 8px 0 10px; font-size: 26px; }
h3 { font-size: 14px; text-transform: uppercase; letter-spacing: .08em; color: var(--cyan); }
.hero-text, .muted { color: var(--muted); max-width: 900px; line-height: 1.55; }
.hero-actions { display: flex; flex-wrap: wrap; gap: 10px; justify-content: flex-end; }
button { cursor: pointer; font-weight: 800; border: 0; }
.primary-btn, .secondary-btn {
  border-radius: 16px; padding: 13px 18px; color: #001529;
  background: linear-gradient(135deg, var(--cyan), var(--cyan-2));
  box-shadow: 0 0 26px rgba(53,243,255,.18);
}
.secondary-btn { color: var(--text); background: rgba(9, 35, 72, .9); border: 1px solid var(--line); }
.secondary-btn.small { padding: 9px 12px; border-radius: 12px; }
.metric-grid { margin-top: 20px; display: grid; grid-template-columns: repeat(6, minmax(150px, 1fr)); gap: 14px; }
.metric {
  padding: 18px; border-radius: 20px; background: var(--panel-2); border: 1px solid var(--line);
}
.metric .value { font-size: 32px; font-weight: 900; margin-top: 8px; }
.metric .source { color: var(--muted); font-size: 12px; margin-top: 4px; }
.panel-grid { display: grid; grid-template-columns: 1.4fr .8fr; gap: 18px; margin-top: 20px; }
.panel { padding: 22px; margin-top: 20px; }
.panel-grid .panel { margin-top: 0; }
.panel-header { display: flex; justify-content: space-between; gap: 16px; align-items: flex-start; }
.pill { border: 1px solid var(--line); color: var(--cyan); border-radius: 999px; padding: 8px 11px; background: rgba(53,243,255,.08); font-size: 12px; font-weight: 800; }
.dual-list { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
ul { padding-left: 20px; }
li { margin: 8px 0; color: #dff7ff; }
.rule-list li::marker { color: var(--cyan); }
.plan-grid { display: grid; grid-template-columns: repeat(4, minmax(180px, 1fr)); gap: 12px; }
.plan-card { border: 1px solid var(--line); border-radius: 18px; padding: 15px; background: rgba(5, 23, 49, .72); }
.plan-card strong { display: block; font-size: 15px; margin: 6px 0; }
.plan-card small { color: var(--muted); line-height: 1.45; }
.inventory-box { max-height: 260px; overflow: auto; padding: 14px; background: #04142b; border-radius: 14px; border: 1px solid var(--line); color: #d9f7ff; white-space: pre-wrap; }
.toast { position: fixed; right: 24px; bottom: 24px; background: #062d52; border: 1px solid var(--cyan); box-shadow: var(--shadow); padding: 14px 18px; border-radius: 16px; max-width: 520px; }
.hidden { display: none; }
@media (max-width: 1100px) {
  .app-shell { grid-template-columns: 1fr; }
  .sidebar { position: static; height: auto; }
  .metric-grid { grid-template-columns: repeat(2, 1fr); }
  .panel-grid, .dual-list { grid-template-columns: 1fr; }
  .plan-grid { grid-template-columns: 1fr; }
  .hero { flex-direction: column; }
}
.role-home { border-color: rgba(53,243,255,.44); }
.home-layout { display: grid; grid-template-columns: 1fr 320px; gap: 18px; align-items: start; }
.module-grid { display: grid; grid-template-columns: repeat(2, minmax(240px, 1fr)); gap: 12px; }
.module-card {
  min-height: 156px;
  border: 1px solid var(--line);
  border-radius: 18px;
  padding: 16px;
  background: rgba(5, 23, 49, .72);
  color: var(--text);
  text-align: left;
  display: grid;
  gap: 8px;
  transition: transform .16s ease, border-color .16s ease, background .16s ease;
}
.module-card:hover, .module-card.selected {
  transform: translateY(-2px);
  border-color: var(--cyan);
  background: linear-gradient(135deg, rgba(13,223,201,.24), rgba(5, 23, 49, .78));
}
.module-card strong { font-size: 18px; }
.module-card small { color: var(--muted); line-height: 1.45; }
.module-card em { color: #dff7ff; font-size: 12px; font-style: normal; opacity: .86; }
.module-status {
  width: max-content;
  border-radius: 999px;
  padding: 6px 9px;
  color: #001529;
  background: linear-gradient(135deg, var(--cyan), var(--cyan-2));
  font-size: 11px;
  font-weight: 900;
}
.hidden-box {
  border: 1px solid rgba(255,189,89,.35);
  border-radius: 18px;
  padding: 18px;
  background: rgba(70, 41, 8, .18);
}
.current-section { border-color: rgba(93,255,176,.3); }
.section-rule {
  margin-top: 18px;
  padding: 18px;
  border-radius: 16px;
  background: rgba(6, 45, 82, .55);
  border: 1px solid var(--line);
  line-height: 1.55;
  color: #dff7ff;
}
.plan-card.active-plan { border-color: var(--good); box-shadow: 0 0 0 1px rgba(93,255,176,.18) inset; }
@media (max-width: 1100px) {
  .home-layout, .module-grid { grid-template-columns: 1fr; }
}
.employee360 { border-color: rgba(93,255,176,.42); }
.employee360-layout { display: grid; grid-template-columns: 380px 1fr; gap: 18px; align-items: stretch; }
.employee-picker, .employee-profile {
  border: 1px solid var(--line);
  border-radius: 20px;
  background: rgba(4, 20, 43, .62);
  padding: 16px;
}
.search-row { display: grid; gap: 10px; }
.clean-input {
  width: 100%;
  padding: 14px 14px;
  border-radius: 14px;
  border: 1px solid var(--line);
  background: rgba(4, 20, 43, .92);
  color: var(--text);
  outline: none;
}
.clean-input:focus { border-color: var(--cyan); box-shadow: 0 0 0 3px rgba(53,243,255,.08); }
.employee-source-summary { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 14px 0; }
.mini-source {
  border: 1px solid rgba(53,243,255,.2);
  border-radius: 14px;
  padding: 11px;
  background: rgba(10, 38, 76, .55);
}
.mini-source strong { display: block; font-size: 24px; }
.mini-source small { color: var(--muted); }
.employee-results { display: grid; gap: 10px; max-height: 520px; overflow: auto; padding-right: 4px; }
.employee-row {
  width: 100%;
  text-align: left;
  display: grid;
  gap: 5px;
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 13px 14px;
  color: var(--text);
  background: rgba(7, 21, 42, .72);
}
.employee-row:hover, .employee-row.selected { border-color: var(--cyan); background: rgba(13, 223, 201, .18); }
.employee-row span { color: #dff7ff; font-size: 12px; }
.employee-row small { color: var(--muted); line-height: 1.35; }
.empty-state {
  min-height: 110px;
  border: 1px dashed rgba(53,243,255,.28);
  border-radius: 16px;
  display: grid;
  place-items: center;
  text-align: center;
  color: var(--muted);
  padding: 20px;
}
.empty-state.large { min-height: 360px; align-content: center; gap: 8px; }
.profile-header { display: flex; justify-content: space-between; gap: 12px; align-items: flex-start; }
.profile-header h2 { font-size: clamp(26px, 3vw, 42px); line-height: 1.05; }
.profile-grid { margin-top: 14px; display: grid; grid-template-columns: repeat(3, minmax(150px, 1fr)); gap: 12px; }
.employee-profile .metric { min-height: 128px; }
.source-map { margin-top: 16px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
.source-pill {
  border: 1px solid rgba(93,255,176,.25);
  border-radius: 14px;
  padding: 12px;
  background: rgba(93,255,176,.08);
}
.source-pill strong { display: block; color: var(--good); }
.source-pill small { color: var(--muted); line-height: 1.35; }
.clean-note {
  margin-top: 16px;
  border-radius: 16px;
  border: 1px solid rgba(53,243,255,.24);
  background: rgba(6, 45, 82, .55);
  padding: 16px;
  line-height: 1.55;
}
@media (max-width: 1100px) {
  .employee360-layout, .profile-grid, .source-map { grid-template-columns: 1fr; }
}
.workday-panel { border-color: rgba(93,255,176,.44); }
.workday-layout { display: grid; grid-template-columns: 1fr 340px; gap: 18px; align-items: stretch; }
.workday-actions, .attendance-source {
  border: 1px solid var(--line);
  border-radius: 20px;
  background: rgba(4, 20, 43, .62);
  padding: 16px;
}
.attendance-card {
  border: 1px solid rgba(53,243,255,.2);
  border-radius: 18px;
  padding: 16px;
  background: rgba(10, 38, 76, .55);
}
.attendance-card h3 { color: var(--text); font-size: 24px; text-transform: none; letter-spacing: 0; margin: 8px 0; }
.button-row { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px; }
.danger-btn { border-color: rgba(255,108,135,.42); color: #ffdce4; }
.session-card { margin-top: 14px; }
.session-status {
  border: 1px solid var(--line);
  border-radius: 18px;
  padding: 16px;
  background: rgba(6, 45, 82, .5);
}
.session-status strong { display: block; font-size: 22px; margin-bottom: 6px; }
.session-status small { color: var(--muted); }
.session-status.active { border-color: var(--good); box-shadow: 0 0 0 1px rgba(93,255,176,.18) inset; }
.session-status.waiting { border-color: rgba(255,189,89,.45); }
.source-warning {
  border: 1px solid rgba(255,189,89,.45);
  border-radius: 16px;
  padding: 14px;
  background: rgba(70, 41, 8, .22);
}
.source-warning strong { display: block; color: var(--warning); margin-bottom: 8px; }
.source-warning small { color: var(--muted); line-height: 1.5; }
.source-pill.wide { margin-bottom: 10px; }
.receipt-list { display: grid; gap: 10px; }
.receipt-row {
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 14px;
  background: rgba(4, 20, 43, .62);
  display: grid;
  gap: 5px;
}
.receipt-row strong { color: var(--good); }
.receipt-row span { color: #dff7ff; }
.receipt-row small { color: var(--muted); }
@media (max-width: 1100px) { .workday-layout { grid-template-columns: 1fr; } }
.task-panel { border-color: rgba(53,243,255,.42); }
.task-layout { display: grid; grid-template-columns: 420px 1fr; gap: 18px; align-items: start; }
.task-list-panel, .task-detail-panel {
  border: 1px solid var(--line);
  border-radius: 20px;
  background: rgba(4, 20, 43, .62);
  padding: 16px;
}
.task-toolbar { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 10px; }
.task-results { display: grid; gap: 10px; max-height: 560px; overflow: auto; padding-right: 4px; }
.task-row {
  width: 100%; text-align: left; display: grid; gap: 6px;
  border: 1px solid var(--line); border-radius: 16px; padding: 14px;
  color: var(--text); background: rgba(7, 21, 42, .72);
}
.task-row:hover, .task-row.selected { border-color: var(--cyan); background: rgba(13, 223, 201, .17); }
.task-row span { color: #dff7ff; font-size: 12px; }
.task-row small { color: var(--muted); line-height: 1.35; }
.task-detail { min-height: 280px; }
.task-action-form { margin-top: 14px; display: grid; gap: 12px; }
.task-action-form label { display: grid; gap: 8px; color: #b9e7ff; font-size: 12px; text-transform: uppercase; letter-spacing: .08em; font-weight: 800; }
.clean-textarea {
  width: 100%; min-height: 110px; resize: vertical;
  padding: 14px; border-radius: 14px; border: 1px solid var(--line);
  background: rgba(4, 20, 43, .92); color: var(--text); outline: none;
}
.clean-textarea:focus { border-color: var(--cyan); box-shadow: 0 0 0 3px rgba(53,243,255,.08); }
@media (max-width: 1100px) { .task-layout { grid-template-columns: 1fr; } }

.closure-panel { border-color: rgba(93,255,176,.48); }
.closure-layout { display: grid; grid-template-columns: 420px 1fr; gap: 18px; align-items: start; }
.closure-queue-panel, .closure-detail-panel {
  border: 1px solid var(--line);
  border-radius: 20px;
  background: rgba(4, 20, 43, .62);
  padding: 16px;
}
@media (max-width: 1100px) { .closure-layout { grid-template-columns: 1fr; } }

.sop-panel { border-color: rgba(255,189,89,.5); }
.sop-layout { display: grid; grid-template-columns: 420px 1fr; gap: 18px; align-items: start; }
.sop-list-panel, .sop-detail-panel {
  border: 1px solid var(--line);
  border-radius: 20px;
  background: rgba(4, 20, 43, .62);
  padding: 16px;
}
.sop-columns { margin-top: 16px; display: grid; grid-template-columns: repeat(2, minmax(240px, 1fr)); gap: 12px; }
.sop-box { border: 1px solid rgba(255,189,89,.28); border-radius: 16px; padding: 14px; background: rgba(70, 41, 8, .14); }
.sop-box h3 { color: var(--warning); }
.sop-box ol { margin: 0; padding-left: 18px; }
.sop-box li { color: #eefbff; line-height: 1.45; }
@media (max-width: 1100px) { .sop-layout, .sop-columns { grid-template-columns: 1fr; } }

.self-service-layout {
  display: grid;
  grid-template-columns: minmax(260px, 360px) 1fr;
  gap: 16px;
}
.self-service-source-panel,
.self-service-detail-panel {
  min-width: 0;
}
.self-service-detail-panel {
  display: grid;
  gap: 14px;
}
@media (max-width: 980px) {
  .self-service-layout { grid-template-columns: 1fr; }
}


.performance-layout { display: grid; grid-template-columns: minmax(280px, 0.9fr) minmax(420px, 1.7fr); gap: 18px; }
.performance-source-panel, .performance-detail-panel { min-width: 0; }
.factor-grid { display: grid; grid-template-columns: repeat(2, minmax(240px, 1fr)); gap: 12px; margin-top: 14px; }
.factor-card { border: 1px solid rgba(125, 231, 255, 0.18); background: rgba(7, 21, 40, 0.62); border-radius: 16px; padding: 14px; display: grid; gap: 8px; }
.factor-card strong { color: #effaff; }
.factor-card .score-line { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
.score-badge { border: 1px solid rgba(125, 231, 255, 0.28); background: rgba(30, 226, 255, 0.08); color: #dffaff; border-radius: 999px; padding: 6px 10px; font-weight: 800; }
.factor-card small { color: #8eaac1; line-height: 1.45; }
.ai-list { display: grid; gap: 8px; margin-top: 10px; }
.ai-list li { margin-left: 18px; color: #bdd5e8; }
@media (max-width: 1100px) { .performance-layout { grid-template-columns: 1fr; } .factor-grid { grid-template-columns: 1fr; } }


/* Build 17 UI Compression */
.ui-compression-panel { border-color: rgba(93,255,176,.5); }
.ui-compression-panel .receipt-row strong { color: var(--text); }
.module-card em + em { color: var(--good); opacity: .92; }
.side-nav small { color: var(--muted); }

/* Build 18A Operational Reality Patch: logo, role separation, operating cockpit */
.nash-logo-card { gap: 12px; align-items: center; }
.nash-logo-mark {
  width: 56px; height: 56px; border-radius: 18px;
  display: grid; place-items: center; position: relative; overflow: hidden;
  background: radial-gradient(circle at 28% 20%, rgba(255,255,255,.34), transparent 30%), linear-gradient(135deg, #00f0ff 0%, #0a78ff 48%, #0b1240 100%);
  border: 1px solid rgba(125,255,255,.75);
  box-shadow: 0 0 26px rgba(0,240,255,.42), inset 0 0 24px rgba(255,255,255,.15);
}
.nash-logo-n { font-weight: 1000; font-size: 32px; letter-spacing: -2px; color: #fff; text-shadow: 0 4px 14px rgba(0,0,0,.35); }
.nash-logo-circuit { position:absolute; inset:auto 7px 7px auto; width:16px; height:16px; border:2px solid rgba(255,255,255,.75); border-left:0; border-top:0; border-radius: 0 0 8px 0; }
.nash-logo-text .brand-title span { color: #00f0ff; letter-spacing: .06em; }
.nash-mini-logo { display:flex; align-items:center; gap:10px; color:#fff; }
.nash-mini-logo span { display:grid; place-items:center; width:36px; height:36px; border-radius:12px; background:linear-gradient(135deg,#00f0ff,#0a78ff); font-weight:1000; box-shadow:0 0 20px rgba(0,240,255,.35); }
.nash-mini-logo em { color:#00f0ff; font-style:normal; }
.operational-workbench { border-color: rgba(0,240,255,.42); box-shadow: 0 0 0 1px rgba(0,240,255,.1), 0 24px 80px rgba(0,20,70,.24); }
.operational-header h2 { font-size: clamp(28px, 4vw, 48px); }
.op-layout { display:grid; grid-template-columns: 310px minmax(0, 1fr); gap:18px; align-items:stretch; }
.op-left, .op-main { border:1px solid rgba(115,190,255,.18); background:rgba(4,24,76,.46); border-radius:24px; padding:18px; }
.op-identity-card { border:1px solid rgba(0,240,255,.2); background:linear-gradient(180deg, rgba(0,240,255,.1), rgba(0,44,120,.1)); border-radius:20px; padding:16px; margin-bottom:14px; }
.op-identity-card p { color:#b9d7ff; margin:10px 0 0; font-size:13px; line-height:1.45; }
.op-metrics { display:grid; gap:10px; margin-bottom:14px; }
.op-metric { padding:12px; border-radius:16px; border:1px solid rgba(115,190,255,.16); background:rgba(1,15,52,.58); }
.op-metric strong { display:block; color:#8ff8ff; text-transform:uppercase; font-size:11px; letter-spacing:.08em; }
.op-metric span { display:block; margin-top:4px; color:#fff; font-weight:900; }
.op-metric small { color:#9db6df; }
.op-metric.live { border-color: rgba(0,240,255,.35); }
.op-flow { display:grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap:10px; margin-bottom:16px; }
.op-lane { min-height:112px; border:1px solid rgba(0,240,255,.18); background:rgba(3,22,70,.58); border-radius:18px; padding:14px; position:relative; }
.op-lane span { display:inline-grid; place-items:center; width:32px; height:32px; border-radius:12px; background:rgba(0,240,255,.14); color:#8ff8ff; font-weight:900; margin-bottom:8px; }
.op-lane strong { display:block; color:#fff; line-height:1.15; }
.op-lane small { display:block; color:#95b2df; margin-top:6px; }
.op-command-buttons { display:flex; flex-wrap:wrap; gap:10px; margin-bottom:16px; }
.op-command-buttons .op-action { min-width: 160px; }
.op-decision-packet { border-top:1px solid rgba(115,190,255,.16); padding-top:12px; }
.receipt-list.compact .receipt-row { padding:10px; }
.role-hidden { display:none !important; }
body.role-employee .hero, body.role-manager .hero, body.role-hr .hero, body.role-executive .hero { min-height: auto; }
body.role-employee .metric-grid, body.role-manager .metric-grid, body.role-hr .metric-grid, body.role-executive .metric-grid { margin-bottom:18px; }
@media (max-width: 1100px) {
  .op-layout { grid-template-columns: 1fr; }
  .op-flow { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}
@media (max-width: 680px) {
  .op-flow { grid-template-columns: 1fr; }
  .op-command-buttons .op-action { width:100%; }
}

/* Build 18B: true operational shell separation */
.operational-workbench { margin-top: 24px; }
.op-packet.active {
  margin-top: 16px;
  border: 1px solid rgba(93,255,176,.35);
  background: rgba(8, 45, 54, .72);
  border-radius: 18px;
  padding: 16px;
}
.op-packet h3 { color: var(--text); text-transform: none; letter-spacing: 0; font-size: 20px; margin: 8px 0 12px; }
.packet-grid { display: grid; grid-template-columns: repeat(4, minmax(120px, 1fr)); gap: 10px; margin: 12px 0; }
.packet-grid div { border: 1px solid rgba(53,243,255,.2); background: rgba(4,20,43,.55); border-radius: 14px; padding: 10px; }
.packet-grid strong { display: block; color: var(--cyan); font-size: 11px; text-transform: uppercase; letter-spacing: .08em; }
.packet-grid span { display: block; color: #fff; font-weight: 800; margin-top: 4px; }
.panel:not(.operational-workbench).role-hidden { display: none !important; }
.panel:not(.operational-workbench):not(.role-hidden)::before {
  content: attr(data-drilldown-label);
  display: inline-block;
  margin-bottom: 10px;
  border: 1px solid rgba(255,189,89,.45);
  color: var(--warning);
  border-radius: 999px;
  padding: 6px 10px;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: .08em;
}
@media (max-width: 1100px) { .packet-grid { grid-template-columns: 1fr; } }


/* Build 18C: true single-surface shell. Legacy informational surfaces are not stacked below the command center. */
.shell-hidden-panel { display: none !important; }
body.single-drilldown-active #operationalWorkbench { display: none !important; }
.drilldown-back-row { display:flex; justify-content:flex-start; margin: 0 0 14px; }
.drilldown-back-row button { border:1px solid rgba(0,245,255,.5); background: rgba(7,19,55,.95); color:#dffcff; border-radius:14px; padding:10px 14px; font-weight:800; cursor:pointer; box-shadow: 0 0 16px rgba(0,245,255,.22); }
.single-surface-lock-note { margin-top: 12px; padding: 12px 14px; border: 1px solid rgba(0,245,255,.24); border-radius: 16px; background: rgba(0,245,255,.08); color: #cdefff; font-size: 13px; }
/* Build 18D — Permissioned Action Console */
.action-only-shell .metric-grid,
.action-only-shell .role-home,
.action-only-shell .plan-grid,
.action-only-shell .final-acceptance-panel,
.action-only-shell .ui-compression-panel,
.action-only-shell .executive-panel,
.action-only-shell .employee360,
.action-only-shell .workday-panel,
.action-only-shell .task-panel,
.action-only-shell .closure-panel,
.action-only-shell .sop-panel,
.action-only-shell .self-service-panel,
.action-only-shell .performance-panel,
.action-only-shell .training-panel,
.action-only-shell .compensation-panel,
.action-only-shell .government-panel,
.action-only-shell .procedures-panel,
.action-only-shell .controls-panel,
.action-only-shell .quality-panel,
.action-only-shell .ai-panel,
.action-only-shell #sectionPanel,
.action-only-shell #planGrid { display: none !important; }
.compact-hero { padding: 24px; }
.compact-hero h1 { font-size: clamp(32px, 4vw, 52px); }
.source-status { margin-top: 18px; display: grid; grid-template-columns: repeat(4, minmax(150px, 1fr)); gap: 12px; }
.source-card { border: 1px solid var(--line); border-radius: 18px; background: var(--panel-2); padding: 16px; display: grid; gap: 6px; }
.source-card b { color: var(--cyan); text-transform: uppercase; font-size: 12px; letter-spacing: .12em; }
.command-console { border-color: rgba(53,243,255,.5); }
.permission-strip { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 12px; }
.permission-card { border: 1px solid var(--line); border-radius: 18px; background: rgba(4,20,43,.6); padding: 16px; }
.permission-card strong { display: block; margin-bottom: 8px; color: var(--cyan); }
.permission-card.block { border-color: rgba(255,108,135,.35); }
.action-grid { margin-top: 18px; display: grid; grid-template-columns: repeat(4, minmax(180px, 1fr)); gap: 12px; }
.action-btn { min-height: 84px; border-radius: 18px; border: 1px solid var(--line); background: rgba(9,35,72,.92); color: var(--text); padding: 16px; text-align: left; box-shadow: 0 0 22px rgba(53,243,255,.08); }
.action-btn.primary { background: linear-gradient(135deg, var(--cyan), var(--cyan-2)); color: #001529; }
.action-btn.danger { border-color: rgba(255,108,135,.6); color: #ffe3e9; background: rgba(91,18,36,.68); }
.work-surface { border-color: rgba(93,255,176,.45); }
.surface-body { display: grid; gap: 14px; }
.selected-context { border: 1px solid rgba(93,255,176,.32); border-radius: 18px; background: rgba(5,55,52,.35); padding: 16px; display: grid; gap: 6px; }
.selected-context span { color: var(--muted); }
.record-list { display: grid; gap: 10px; max-height: 440px; overflow: auto; }
.record-row { width: 100%; text-align: left; display: grid; gap: 6px; border: 1px solid var(--line); border-radius: 16px; padding: 14px; color: var(--text); background: rgba(7,21,42,.75); }
.record-row:hover,.record-row.selected { border-color: var(--cyan); background: rgba(13,223,201,.18); }
.record-row span { color: var(--muted); font-size: 13px; }
.detail-card { border: 1px solid var(--line); border-radius: 18px; background: rgba(4,20,43,.65); padding: 16px; }
.detail-grid { margin-top: 12px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
.detail-grid span { border: 1px solid rgba(53,243,255,.16); border-radius: 14px; padding: 12px; display: grid; gap: 5px; }
.detail-grid b { color: var(--cyan); font-size: 12px; text-transform: uppercase; }
.form-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
.form-field { display: grid; gap: 8px; color: var(--cyan); font-weight: 800; font-size: 12px; text-transform: uppercase; letter-spacing: .08em; }
.form-field textarea { width: 100%; border: 1px solid var(--line); border-radius: 14px; background: rgba(4,20,43,.9); color: var(--text); padding: 12px; }
.receipt-card { border: 1px solid var(--line); border-radius: 16px; padding: 14px; background: rgba(4,20,43,.72); display: grid; gap: 6px; }
.receipt-card span { color: var(--good); font-weight: 800; }
.receipt-card small { color: var(--muted); }
.receipt-card pre, .object-box { max-height: 320px; overflow: auto; padding: 12px; border-radius: 12px; background: #04142b; color: #dff7ff; white-space: pre-wrap; }
@media (max-width: 1100px) { .source-status, .permission-strip, .action-grid, .detail-grid, .form-grid { grid-template-columns: 1fr; } }

/* Build Final Gold Master — strict action-first console */
.final-os-shell .final-hero { padding: 22px; }
.final-os-shell .final-hero h1 { font-size: clamp(30px, 4vw, 50px); }
.final-os-shell .hero-text { max-width: 760px; }
.final-os-shell .command-console { min-height: 420px; }
.command-grid { grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); }
.command-card { min-height: 112px; display: flex; flex-direction: column; justify-content: space-between; align-items: flex-start; text-align: left; }
.command-card span { font-size: 15px; }
.command-card small { display: block; margin-top: 10px; color: var(--muted); line-height: 1.35; font-weight: 600; }
.command-card.add, .command-card.edit, .command-card.execute { border-color: rgba(93,255,176,.48); }
.command-card.delete, .action-btn.delete { border-color: rgba(255,108,135,.68); color: #ffdbe2; }
.compact-permissions { grid-template-columns: 1fr 1fr; }
.compact-permissions .permission-card { display: flex; flex-wrap: wrap; gap: 8px; align-content: flex-start; }
.compact-permissions .permission-card strong { flex: 1 0 100%; }
.compact-permissions .permission-card span { border: 1px solid var(--line); border-radius: 999px; padding: 6px 9px; color: #dff7ff; background: rgba(53,243,255,.06); font-size: 12px; }
.operation-surface { border-color: rgba(93,255,176,.38); }
.record-list { display: grid; gap: 10px; margin-top: 16px; }
.record-row { width: 100%; border: 1px solid var(--line); background: rgba(4, 26, 54, .88); color: var(--text); border-radius: 16px; padding: 14px; text-align: left; }
.record-row strong { display: block; }
.record-row span { color: var(--muted); display: block; margin-top: 5px; }
.selected-context { border: 1px solid rgba(93,255,176,.4); background: rgba(3, 42, 55, .8); border-radius: 18px; padding: 14px; margin: 14px 0; display: grid; gap: 5px; }
.selected-context span { color: var(--muted); }
.detail-card, .empty-state { border: 1px solid var(--line); border-radius: 18px; padding: 16px; background: rgba(4, 26, 54, .78); margin: 12px 0; }
.detail-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; }
.detail-grid span { border: 1px solid var(--line); border-radius: 14px; padding: 10px; color: var(--muted); }
.detail-grid b { display: block; color: var(--cyan); margin-bottom: 5px; }
.form-field { display: grid; gap: 8px; margin: 12px 0; }
.form-field span { color: var(--cyan); font-weight: 800; font-size: 12px; letter-spacing: .08em; text-transform: uppercase; }
.form-field textarea { background: #061a38; color: var(--text); border: 1px solid var(--line); border-radius: 14px; padding: 12px; font-family: inherit; }
.object-box { max-height: 360px; overflow: auto; background: #031225; border: 1px solid var(--line); border-radius: 16px; padding: 14px; color: #dbf9ff; white-space: pre-wrap; }
.receipt-list { display: grid; gap: 12px; margin-top: 14px; }
.receipt-card { border: 1px solid rgba(93,255,176,.34); background: rgba(0, 36, 45, .7); border-radius: 18px; padding: 14px; display: grid; gap: 7px; }
.receipt-card span { color: var(--good); font-weight: 800; }
.receipt-card small { color: var(--muted); }
.receipt-card pre { max-height: 220px; overflow: auto; background: rgba(0,0,0,.22); border-radius: 12px; padding: 10px; color: #e9feff; }
.side-nav .nav-item small { display: block; color: var(--muted); margin-top: 4px; font-size: 11px; }

/* Final Gold Hotfix 02 — Executive-grade Action Ledger UX */
.ledger-summary { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; margin: 14px 0; }
.ledger-summary div { border: 1px solid var(--line); border-radius: 16px; background: rgba(4, 26, 54, .72); padding: 14px; display: grid; gap: 5px; }
.ledger-summary strong { color: var(--cyan); font-size: 22px; }
.ledger-summary span { color: var(--muted); font-size: 12px; font-weight: 800; letter-spacing: .04em; text-transform: uppercase; }
.business-receipt { border-color: rgba(93,255,176,.42) !important; background: linear-gradient(180deg, rgba(0, 40, 58, .88), rgba(2, 18, 41, .82)) !important; }
.receipt-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; }
.receipt-top h3 { margin: 0; font-size: 19px; }
.status-pill { border: 1px solid rgba(93,255,176,.38); background: rgba(93,255,176,.12); color: var(--good) !important; border-radius: 999px; padding: 8px 10px; white-space: nowrap; font-size: 12px; }
.receipt-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; }
.receipt-grid span { border: 1px solid rgba(255,255,255,.09); border-radius: 12px; padding: 10px; color: var(--text) !important; background: rgba(255,255,255,.035); font-weight: 700; }
.receipt-grid b { display: block; color: var(--muted); font-size: 11px; text-transform: uppercase; margin-bottom: 4px; }
.receipt-note { border-left: 3px solid var(--cyan); padding: 10px 12px; border-radius: 10px; background: rgba(13,223,201,.08); color: var(--text); }
.technical-trace { border: 1px dashed rgba(255,255,255,.18); border-radius: 12px; padding: 10px; color: var(--muted); }
.technical-trace summary { cursor: pointer; font-weight: 800; color: var(--muted); }
.technical-trace pre { margin-top: 10px; }
@media (max-width: 900px) { .ledger-summary, .receipt-grid { grid-template-columns: 1fr; } .receipt-top { flex-direction: column; } }


/* Final Gold Hotfix 03 — Downloadable Evidence Files + Employee Document Vault */
.file-field input[type="file"] {
  width: 100%;
  border: 1px solid var(--line);
  border-radius: 14px;
  background: rgba(4,20,43,.9);
  color: var(--text);
  padding: 12px;
}
.inline-select {
  margin-top: 0;
}
.document-grid {
  display: grid;
  gap: 12px;
  margin: 14px 0;
}
.document-card {
  border: 1px solid rgba(93,255,176,.42);
  background: linear-gradient(180deg, rgba(0, 40, 58, .84), rgba(2, 18, 41, .78));
  border-radius: 18px;
  padding: 16px;
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 14px;
  align-items: center;
}
.document-card h3 {
  margin: 0 0 6px;
  font-size: 18px;
  color: var(--text);
  text-transform: none;
  letter-spacing: 0;
}
.document-card strong { display:block; color:#fff; margin-bottom:6px; }
.document-card small { display:block; color:var(--muted); line-height:1.45; }
.receipt-document-line {
  border: 1px solid rgba(53,243,255,.22);
  border-radius: 14px;
  background: rgba(53,243,255,.07);
  padding: 12px;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(180px, .6fr) auto;
  gap: 10px;
  align-items: center;
}
.receipt-document-line span {
  color: var(--text) !important;
  font-weight: 800;
}
.receipt-document-line b {
  display: block;
  color: var(--muted);
  font-size: 11px;
  text-transform: uppercase;
  margin-bottom: 4px;
}
@media (max-width: 900px) {
  .document-card,
  .receipt-document-line { grid-template-columns: 1fr; }
}

/* Final Gold Hotfix 04 — Document lifecycle, verification, expiry, manager evidence review */
.doc-meta {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8px;
  margin: 10px 0;
}
.doc-meta span {
  border: 1px solid rgba(255,255,255,.09);
  border-radius: 12px;
  background: rgba(255,255,255,.035);
  padding: 8px;
  color: var(--text);
  font-weight: 800;
}
.doc-meta b {
  display: block;
  color: var(--muted);
  font-size: 10px;
  text-transform: uppercase;
  margin-bottom: 4px;
}
.document-actions { display: grid; gap: 8px; align-content: center; justify-items: stretch; }
.document-card.soon-doc { border-color: rgba(255, 202, 88, .72); }
.document-card.expired-doc { border-color: rgba(255, 93, 121, .75); }
.secondary-btn.danger { border-color: rgba(255,93,121,.45); color: #ffd5db; }
@media (max-width: 900px) { .doc-meta { grid-template-columns: 1fr; } }
